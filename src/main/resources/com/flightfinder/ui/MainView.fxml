<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressIndicator?>
<?import javafx.scene.control.Spinner?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.control.ScrollPane?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.flightfinder.ui.MainView"
            style="-fx-background-color: #F8F9FA;">

    <top>
        <VBox>
            <!-- ── Navigation Bar: Flights only ── -->
            <HBox styleClass="nav-bar" alignment="CENTER_LEFT" spacing="0">
                <!-- Logo -->
                <HBox alignment="CENTER_LEFT" spacing="8">
                    <StackPane style="-fx-background-color: #3772FF; -fx-background-radius: 6px;"
                               prefWidth="30" prefHeight="30">
                        <Label text="✈" style="-fx-text-fill: white; -fx-font-size: 14px;"/>
                    </StackPane>
                    <Label text="dream" styleClass="nav-logo"/>
                    <Label text="fly" style="-fx-font-size: 20px; -fx-font-weight: 800; -fx-text-fill: #3772FF;"/>
                </HBox>

                <Region HBox.hgrow="ALWAYS"/>

                <!-- Only FLIGHTS in nav -->
                <HBox spacing="4" alignment="CENTER">
                    <Button text="FLIGHTS" styleClass="nav-link-active"/>
                </HBox>

                <Region HBox.hgrow="ALWAYS"/>

                <!-- My Bookings and Sign In -->
                <HBox spacing="12" alignment="CENTER">
                    <Button text="MY BOOKINGS" style="-fx-background-color: transparent; -fx-text-fill: #1A1A1A; -fx-font-size: 13px; -fx-font-weight: 800; -fx-cursor: hand;" onAction="#handleMyBookings"/>
                    <Button text="SIGN IN" styleClass="nav-sign-in"/>
                    <StackPane style="-fx-background-color: #E2E8F0; -fx-background-radius: 50%;"
                               prefWidth="34" prefHeight="34">
                        <Label text="👤" style="-fx-font-size: 16px;"/>
                    </StackPane>
                </HBox>
            </HBox>

            <!-- ── Search Panel ── -->
            <VBox styleClass="search-panel" spacing="14">

                <!-- Trip type row + passengers + cabin class -->
                <HBox spacing="0" alignment="CENTER_LEFT">

                    <!-- Trip type toggle group -->
                    <HBox spacing="4">
                        <Button fx:id="btnRoundTrip"  text="ROUND TRIP"  styleClass="trip-type-btn-active" onAction="#handleRoundTrip"/>
                        <Button fx:id="btnOneWay"     text="ONE WAY"     styleClass="trip-type-btn"        onAction="#handleOneWay"/>
                        <Button fx:id="btnMultiCity"  text="MULTI-CITY"  styleClass="trip-type-btn"        onAction="#handleMultiCity"/>
                    </HBox>

                    <!-- Passenger counter -->
                    <HBox spacing="8" alignment="CENTER" style="-fx-padding: 0 0 0 20;">
                        <Button fx:id="btnDecPassenger" text="−"
                                onAction="#decreasePassengers"
                                style="-fx-background-color: #F0F4F8; -fx-text-fill: #1A1A1A; -fx-font-size: 16px; -fx-font-weight: 700; -fx-background-radius: 50%; -fx-min-width: 28px; -fx-min-height: 28px; -fx-cursor: hand; -fx-border-width: 0;"/>
                        <Label fx:id="passengerLabel"
                               text="1"
                               style="-fx-text-fill: #1A1A1A; -fx-font-size: 14px; -fx-font-weight: 700; -fx-min-width: 18px; -fx-alignment: center;"/>
                        <Label text="PASSENGER"
                               style="-fx-text-fill: #6B7A99; -fx-font-size: 11px; -fx-font-weight: 600;"/>
                        <Button fx:id="btnIncPassenger" text="+"
                                onAction="#increasePassengers"
                                style="-fx-background-color: #F0F4F8; -fx-text-fill: #1A1A1A; -fx-font-size: 16px; -fx-font-weight: 700; -fx-background-radius: 50%; -fx-min-width: 28px; -fx-min-height: 28px; -fx-cursor: hand; -fx-border-width: 0;"/>
                    </HBox>

                    <Region HBox.hgrow="ALWAYS"/>

                    <!-- Cabin class buttons -->
                    <HBox spacing="4">
                        <Button fx:id="btnEconomy"  text="ECONOMY"  styleClass="class-btn-active" onAction="#selectEconomy"/>
                        <Button fx:id="btnPremium"  text="PREMIUM"  styleClass="class-btn"        onAction="#selectPremium"/>
                        <Button fx:id="btnBusiness" text="BUSINESS" styleClass="class-btn"        onAction="#selectBusiness"/>
                        <Button fx:id="btnFirst"    text="FIRST"    styleClass="class-btn"        onAction="#selectFirst"/>
                    </HBox>
                </HBox>

                <!-- Input fields row -->
                <GridPane hgap="12" vgap="0">
                    <!-- Origin -->
                    <VBox GridPane.columnIndex="0" GridPane.rowIndex="0" spacing="4"
                          style="-fx-background-color: #FFFFFF; -fx-background-radius: 10px; -fx-padding: 10 14 10 14; -fx-border-color: #E2E8F0; -fx-border-radius: 10px; -fx-border-width: 1px;"
                          prefWidth="195">
                        <Label text="· ORIGIN" styleClass="field-label"/>
                        <ComboBox fx:id="originCombo" editable="true" prefWidth="170"
                                  style="-fx-background-color: transparent; -fx-border-width: 0; -fx-font-size: 14px; -fx-font-weight: 700;"/>
                    </VBox>

                    <!-- Swap icon -->
                    <StackPane GridPane.columnIndex="1" GridPane.rowIndex="0" alignment="CENTER" prefWidth="36">
                        <StackPane style="-fx-background-color: #FFFFFF; -fx-background-radius: 50%; -fx-border-color: #E2E8F0; -fx-border-radius: 50%; -fx-border-width: 1px;"
                                   prefWidth="30" prefHeight="30">
                            <Label text="⇄" style="-fx-text-fill: #3772FF; -fx-font-size: 13px;"/>
                        </StackPane>
                    </StackPane>

                    <!-- Destination -->
                    <VBox GridPane.columnIndex="2" GridPane.rowIndex="0" spacing="4"
                          style="-fx-background-color: #FFFFFF; -fx-background-radius: 10px; -fx-padding: 10 14 10 14; -fx-border-color: #E2E8F0; -fx-border-radius: 10px; -fx-border-width: 1px;"
                          prefWidth="195">
                        <Label text="· DESTINATION" styleClass="field-label"/>
                        <ComboBox fx:id="destinationCombo" editable="true" prefWidth="170"
                                  style="-fx-background-color: transparent; -fx-border-width: 0; -fx-font-size: 14px; -fx-font-weight: 700;"/>
                    </VBox>

                    <!-- Departure date -->
                    <VBox GridPane.columnIndex="3" GridPane.rowIndex="0" spacing="4"
                          style="-fx-background-color: #FFFFFF; -fx-background-radius: 10px; -fx-padding: 10 14 10 14; -fx-border-color: #E2E8F0; -fx-border-radius: 10px; -fx-border-width: 1px;"
                          prefWidth="155">
                        <Label text="· DEPARTURE" styleClass="field-label"/>
                        <DatePicker fx:id="departureDate" prefWidth="130"
                                    style="-fx-background-color: transparent; -fx-border-width: 0; -fx-font-size: 14px; -fx-font-weight: 700;"/>
                    </VBox>

                    <!-- Return date (hidden in One Way mode) -->
                    <VBox GridPane.columnIndex="4" GridPane.rowIndex="0" fx:id="returnDateBox" spacing="4"
                          style="-fx-background-color: #FFFFFF; -fx-background-radius: 10px; -fx-padding: 10 14 10 14; -fx-border-color: #E2E8F0; -fx-border-radius: 10px; -fx-border-width: 1px;"
                          prefWidth="155">
                        <Label text="· RETURN" styleClass="field-label"/>
                        <DatePicker fx:id="returnDate" prefWidth="130"
                                    style="-fx-background-color: transparent; -fx-border-width: 0; -fx-font-size: 14px; -fx-font-weight: 500; -fx-text-fill: #6B7A99;"/>
                    </VBox>

                    <!-- Search button -->
                    <HBox GridPane.columnIndex="5" GridPane.rowIndex="0"
                          alignment="CENTER" spacing="10" style="-fx-padding: 0 0 0 8;">
                        <Button fx:id="searchButton" text="🔍  SEARCH FLIGHTS"
                                styleClass="button-primary" onAction="#handleSearch"
                                prefHeight="54"/>
                        <ProgressIndicator fx:id="progressIndicator" visible="false"
                                           prefHeight="24" prefWidth="24"/>
                    </HBox>
                </GridPane>

                <!-- Hidden spinner kept for data binding; actual UI is passengerLabel + ± buttons -->
                <Spinner fx:id="passengersSpinner" visible="false" managed="false"
                         prefWidth="1" prefHeight="1"/>

            </VBox>

            <!-- ── Sort / Status bar ── -->
            <HBox alignment="CENTER_LEFT" spacing="6"
                  style="-fx-background-color: #FFFFFF; -fx-border-color: transparent transparent #E2E8F0 transparent; -fx-border-width: 0 0 1 0; -fx-padding: 10 16 10 16;">
                <Label fx:id="statusLabel" styleClass="results-meta" text="Ready to search"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label text="SORT BY" styleClass="sort-label"/>
                <ComboBox fx:id="sortCombo" prefWidth="185"
                          style="-fx-background-color: #FFFFFF; -fx-border-color: #E2E8F0; -fx-border-radius: 8px; -fx-background-radius: 8px; -fx-text-fill: #1A1A1A; -fx-font-size: 11px; -fx-font-weight: 700;"/>
            </HBox>
        </VBox>
    </top>

    <!-- ── Left Filter Panel ── -->
    <left>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" style="-fx-background: #F8F9FA; -fx-background-color: #F8F9FA; -fx-border-width: 0;">
            <VBox fx:id="filterContainer" styleClass="filter-panel" prefWidth="245"
                  style="-fx-min-height: 600;"/>
        </ScrollPane>
    </left>

    <!-- ── Center Results ── -->
    <center>
        <VBox fx:id="resultsContainer" style="-fx-background-color: #F8F9FA;"/>
    </center>

</BorderPane>
